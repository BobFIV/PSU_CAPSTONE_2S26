[Unit]
Description=Capstone ACME CSE
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=raaid
WorkingDirectory=/home/raaid/Desktop/capstone2
ExecStart=/home/raaid/Desktop/capstone2/systemd/run_acme.sh
Restart=always
RestartSec=3
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
