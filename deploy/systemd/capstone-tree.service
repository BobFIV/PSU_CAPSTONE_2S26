[Unit]
Description=Capstone ACME Tree Initialization
After=capstone-acme.service
Requires=capstone-acme.service

[Service]
Type=oneshot
User=raaid
WorkingDirectory=/home/raaid/Desktop/capstone2
ExecStart=/home/raaid/Desktop/capstone2/systemd/run_tree_init.sh
RemainAfterExit=yes

[Install]
WantedBy=multi-user.target
